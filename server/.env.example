PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/queuekart?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
# Single origin, * for any, or comma-separated (prod + Metro), e.g.:
# CLIENT_ORIGIN=https://queuekart.onrender.com,http://localhost:8081
CLIENT_ORIGIN=*

# Optional: email (Brevo)
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=QueueKart

# Razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Customer “skip to 2nd in queue”: min waiting customers before paid option appears (must match app default 5)
# QUEUE_PRIORITY_WAITING_THRESHOLD=5
# QUEUE_PRIORITY_PRICE_PAISE=2500

# Optional: protect POST /api/ads/units (header X-Ads-Admin-Key)
# ADS_ADMIN_KEY=
